{
	"name": "Existing Docker Compose (Extend)",
	"dockerComposeFile": "docker-compose.yml",
	"service": "python",
	"workspaceFolder": "/workspaces/workspace",
    "postStartCommand": "python3 -m venv .venv && . .venv/bin/activate && pip install -r requirements.txt",
    "customizations": {
        "vscode": {
            "extensions": [
                // Docker
                "ms-azuretools.vscode-docker",
                // Python
                "ms-python.python",
                "ms-python.vscode-pylance",
                "charliermarsh.ruff",
                "KevinRose.vsc-python-indent",
                "njpwerner.autodocstring",
                // Github copilot
                "GitHub.copilot",
                "GitHub.copilot-chat"
            ]
        }
    }
}